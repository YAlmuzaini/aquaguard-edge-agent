# Edge agent environment (example)
# Copy this file to .env and fill real values.

# Ingestion endpoint (Edge Function URL)
INGEST_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/ingest-telemetry

# Shared secret sent to the Supabase ingest function as Authorization/x-ingest-secret.
# This must match aquaguard-backend-supabase INGEST_SHARED_SECRET.
INGEST_TOKEN=CHANGE_ME_LONG_RANDOM_STRING

# Device + payload settings
DEVICE_ID=SN-01
SCHEMA_VERSION=1.0
MODE=simulate

# Sampling and retry behavior
SAMPLE_INTERVAL_SEC=10
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_MS=1000
REQUEST_TIMEOUT_SEC=10

# Local queue
QUEUE_PATH=./data/telemetry_queue.jsonl
QUEUE_MAX_ITEMS=10000
